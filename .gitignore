# Create .gitignore file
echo __pycache__/ > .gitignore
echo *.pyc >> .gitignore
echo .venv/ >> .gitignore
echo venv/ >> .gitignore
echo env/ >> .gitignore
echo .env >> .gitignore
echo *.log >> .gitignore
echo .DS_Store >> .gitignore
echo .vscode/ >> .gitignore
echo .idea/ >> .gitignore
echo *.db >> .gitignore
echo *.sqlite3 >> .gitignore